# Image to run on the VM.
LLM_WIKI_IMAGE=us-central1-docker.pkg.dev/your-project-id/llm-wiki/llm-wiki-prompt-packet:latest

# Host paths on the VM for persistent packet data.
LLM_WIKI_VAULT_HOST_PATH=/srv/llm-wiki/vault
LLM_WIKI_HOME_HOST_PATH=/srv/llm-wiki/home
LLM_WIKI_QMD_SOURCE_HOST_PATH=
LLM_WIKI_GITVIZZ_SOURCE_HOST_PATH=

# External MCP port exposed by Docker on the VM.
LLM_WIKI_MCP_BIND_HOST=127.0.0.1
LLM_WIKI_MCP_PORT=8181

# Packet bootstrap settings.
LLM_WIKI_TARGETS=claude,codex,droid
LLM_WIKI_FORCE_INSTALL=0
LLM_WIKI_SKIP_GITVIZZ=1
LLM_WIKI_ENABLE_GITVIZZ=0
LLM_WIKI_GITVIZZ_SOURCE=/gitvizz-source
LLM_WIKI_GITVIZZ_REPO_URL=
LLM_WIKI_GITVIZZ_CHECKOUT_PATH=
LLM_WIKI_GITVIZZ_REPO_PATH=
LLM_WIKI_GITVIZZ_FRONTEND_URL=
LLM_WIKI_GITVIZZ_BACKEND_URL=
LLM_WIKI_GITVIZZ_WAIT_TIMEOUT=120
LLM_WIKI_QMD_SOURCE=
LLM_WIKI_QMD_REPO_URL=https://github.com/kingkillery/pk-qmd
# Leave blank to keep the packet config on http://127.0.0.1:8181/mcp inside the VM.
# For hosted clients, set this to your Cloudflare Worker or Tunnel URL such as
# https://mcp.example.com/mcp before deployment.
LLM_WIKI_QMD_MCP_URL=
LLM_WIKI_BRV_COMMAND=brv
LLM_WIKI_MCP_SERVER_CMD=pk-qmd mcp
LLM_WIKI_MCP_UPSTREAM_HOST=127.0.0.1
LLM_WIKI_AGENT_API_TOKEN=

# Optional GitVizz sidecar settings. To run GitVizz inside the VM's Docker stack,
# set LLM_WIKI_ENABLE_GITVIZZ=1 and provide LLM_WIKI_GITVIZZ_SOURCE_HOST_PATH
# pointing at a real GitVizz checkout on the VM.
LLM_WIKI_GITVIZZ_MONGO_URI=
LLM_WIKI_GITVIZZ_PHOENIX_ENDPOINT=
LLM_WIKI_GITVIZZ_PHOENIX_PROJECT_NAME=
LLM_WIKI_GITVIZZ_FRONTEND_PORT=3000
LLM_WIKI_GITVIZZ_BACKEND_PORT=8003
LLM_WIKI_GITVIZZ_PHOENIX_PORT=6006
LLM_WIKI_GITVIZZ_PHOENIX_GRPC_PORT=4317
LLM_WIKI_GITVIZZ_BIND_HOST=127.0.0.1

# Optional credentials.
BYTEROVER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
GH_TOKEN=
GITHUB_TOKEN=
