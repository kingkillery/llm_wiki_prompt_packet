# Image to run on the VM.
LLM_WIKI_IMAGE=us-central1-docker.pkg.dev/your-project-id/llm-wiki/llm-wiki-prompt-packet:latest

# Host paths on the VM for persistent packet data.
LLM_WIKI_VAULT_HOST_PATH=/srv/llm-wiki/vault
LLM_WIKI_HOME_HOST_PATH=/srv/llm-wiki/home
LLM_WIKI_QMD_SOURCE_HOST_PATH=

# External MCP port exposed by Docker on the VM.
LLM_WIKI_MCP_PORT=8181

# Packet bootstrap settings.
LLM_WIKI_TARGETS=claude,codex,droid
LLM_WIKI_FORCE_INSTALL=0
LLM_WIKI_SKIP_GITVIZZ=1
LLM_WIKI_QMD_SOURCE=
LLM_WIKI_QMD_REPO_URL=https://github.com/kingkillery/pk-qmd
# Leave blank to auto-generate a public VM URL like http://<vm-ip>:8181/mcp.
LLM_WIKI_QMD_MCP_URL=
LLM_WIKI_BRV_COMMAND=brv
LLM_WIKI_MCP_SERVER_CMD=pk-qmd mcp

# Optional credentials.
BYTEROVER_API_KEY=
GEMINI_API_KEY=
GH_TOKEN=
GITHUB_TOKEN=
